addon "svm" {
    rpc_api_url = input.rpc_api_url
    network_id = input.network_id
}

# DEPLOYMENT
action "deploy_mock_portal" "svm::deploy_program" {
    description = "Deploy mock_portal program"
    program = svm::get_program_from_anchor_project("mock_portal")
    authority = signer.authority
    payer = signer.payer
    instant_surfnet_deployment = true
}

action "deploy_order_book" "svm::deploy_program" {
    description = "Deploy order_book program"
    program = svm::get_program_from_anchor_project("order_book")
    authority = signer.authority
    payer = signer.payer
    instant_surfnet_deployment = true
    depends_on = [action.deploy_mock_portal]
}

# INITIALIZATION
variable "orderbook_program" {
    value = svm::get_program_from_anchor_project("order_book")
}
variable "messenger_authority" {
    value = svm::find_pda("MzBrgc8yXBj4P16GTkcSyDZkEQZB9qDqf3fh9bByJce", ["authority"])
}

action "initialize_orderbook" "svm::process_instructions" {
    description = "Initializes the order_book program"
    signers = [signer.caller]
    instruction {
        program_idl = variable.orderbook_program.idl
        instruction_name = "initialize"
        admin {
            public_key = signer.caller.public_key
        }
        instruction_args = [input.chain_id, variable.messenger_authority.pda]
    }
    depends_on = [action.deploy_order_book]
}

# CONFIGURATION SEPOLIA
action "configure_destination_eth" "svm::process_instructions" {
    description = "Configures a destination chain (Ethereum)"
    signers = [signer.caller]
    instruction {
        program_idl = variable.orderbook_program.idl
        instruction_name = "add_destination"
        admin {
            public_key = signer.caller.public_key
        }
        destination_account {
            public_key = "9sKXCLNYtDAtGpSssvQHj7zkAACutH3N9hRpSkpysp5Z"
        }
        instruction_args = [11155111]
    }
    depends_on = [action.initialize_orderbook]
}

# CONFIGURATION ARBITRUM SEPOLIA
action "configure_destination_base" "svm::process_instructions" {
    description = "Configures a destination chain (Base)"
    signers = [signer.caller]
    instruction {
        program_idl = variable.orderbook_program.idl
        instruction_name = "add_destination"
        admin {
            public_key = signer.caller.public_key
        }
        destination_account {
            public_key = "4vbJ2P91EtA72GKyCG2ZS6eGDHgN9oZtCUH3syFJRpXa"
        }
        instruction_args = [421614]
    }
    depends_on = [action.initialize_orderbook]
}
