# Development/Testnet Environment
# Uses 1Password references - run with: op run --env-file=.env.dev -- <command>

# Private keys (1Password reference)
DEPLOYER_PRIVATE_KEY="op://Protocol Accounts/Protocol One LTD/Private key"
ADMIN_PRIVATE_KEY="op://Web3/Dev - Deployer/private key"

# Admin address for OrderBook (receives DEFAULT_ADMIN_ROLE)
ADMIN_ADDRESS="op://Web3/Dev - Deployer/wallet address"
PAUSER_ADDRESS="op://Web3/Dev - Deployer/wallet address"
# ADMIN_ADDRESS="op://Protocol Accounts/Protocol One LTD/Address"
# PAUSER_ADDRESS="op://Protocol Accounts/Protocol One LTD/Address"

# Portal contract address (same across all EVM chains)
PORTAL_ADDRESS="0x50D65829Eae411B655bAA92539E4F8c46D20638C"

# Etherscan API key for verification
ETHERSCAN_API_KEY="op://Web3/Etherscan/API KEY"

# RPC URLs
SEPOLIA_RPC_URL="op://Web3/Alchemy/sepolia"
ARBITRUM_SEPOLIA_RPC_URL="op://Web3/Alchemy/arbitrum-sepolia"
BASE_SEPOLIA_RPC_URL="op://Web3/Alchemy/base-sepolia"
