# Development/Testnet Environment
# Uses 1Password references - run with: op run --env-file=.env.dev -- <command>

# Deployer private key (1Password reference)
PRIVATE_KEY="op://Web3/Dev - Deployer/private key"

# Admin address for OrderBook (receives DEFAULT_ADMIN_ROLE)
ADMIN_ADDRESS="op://Web3/Dev - Deployer/wallet address"

# Portal contract address (same across all EVM chains)
PORTAL_ADDRESS="0xD925C84b55E4e44a53749fF5F2a5A13F63D128fd"

# Etherscan API key for verification
ETHERSCAN_API_KEY="op://Web3/Etherscan/API KEY"

# RPC URLs
SEPOLIA_RPC_URL="op://Web3/Alchemy/sepolia"
ARBITRUM_SEPOLIA_RPC_URL="op://Web3/Alchemy/arbitrum-sepolia"
