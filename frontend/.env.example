# Network mode: 'local' | 'devnet' | 'mainnet'
VITE_NETWORK=local

# Quoter API URL
VITE_QUOTER_URL=http://localhost:3000

# RPC endpoints (for local development)
VITE_ANVIL_RPC=http://localhost:8545
VITE_SURFPOOL_RPC=http://localhost:8899

# Reown AppKit Project ID (required for devnet/mainnet)
VITE_REOWN_PROJECT_ID=

# Private keys for local development (do not use in production)
VITE_LOCAL_EVM_PRIVATE_KEY=
VITE_LOCAL_SVM_PRIVATE_KEY=
